      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "right", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "editorMode": "code", "expr": "100 - (avg by(instance)(rate(node_cpu_seconds_total{job=\"kiosk-nodes\", mode=\"idle\", instance=~\"$instance\"}[5m])) * 100)", "legendFormat": "{{instance}}", "refId": "A"}]
    },
    {
