      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "background", "graphMode": "area", "textMode": "value"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "editorMode": "code", "expr": "max((1 - node_memory_MemAvailable_bytes{job=\"kiosk-nodes\", instance=~\"$instance\"} / node_memory_MemTotal_bytes{job=\"kiosk-nodes\", instance=~\"$instance\"}) * 100)", "refId": "A"}]
    },
    {
