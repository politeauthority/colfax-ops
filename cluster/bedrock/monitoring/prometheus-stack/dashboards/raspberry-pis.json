      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "editorMode": "code", "expr": "(1 - node_memory_MemAvailable_bytes{job=\"kiosk-nodes\", instance=~\"$instance\"} / node_memory_MemTotal_bytes{job=\"kiosk-nodes\", instance=~\"$instance\"}) * 100", "legendFormat": "{{instance}}", "refId": "A"}]
