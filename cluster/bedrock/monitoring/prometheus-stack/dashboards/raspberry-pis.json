      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "value", "graphMode": "none", "textMode": "value_and_name", "orientation": "horizontal"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "editorMode": "code", "expr": "time() - node_boot_time_seconds{job=\"kiosk-nodes\", instance=~\"$instance\"}", "legendFormat": "{{instance}}", "refId": "A"}]
