      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "background", "graphMode": "area", "textMode": "value"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "editorMode": "code", "expr": "max((1 - node_filesystem_avail_bytes{job=\"kiosk-nodes\", mountpoint=\"/\", instance=~\"$instance\"} / node_filesystem_size_bytes{job=\"kiosk-nodes\", mountpoint=\"/\", instance=~\"$instance\"}) * 100)", "refId": "A"}]
    },
    {
