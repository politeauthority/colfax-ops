      "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "editorMode": "code", "expr": "sum by(instance)(rate(node_network_receive_bytes_total{job=\"kiosk-nodes\", device!~\"lo|veth.*|docker.*\", instance=~\"$instance\"}[5m]))", "legendFormat": "{{instance}} rx", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "editorMode": "code", "expr": "-sum by(instance)(rate(node_network_transmit_bytes_total{job=\"kiosk-nodes\", device!~\"lo|veth.*|docker.*\", instance=~\"$instance\"}[5m]))", "legendFormat": "{{instance}} tx", "refId": "B"}
