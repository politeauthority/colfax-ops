      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "right", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "editorMode": "code", "expr": "node_load1{job=\"kiosk-nodes\", instance=~\"$instance\"}", "legendFormat": "{{instance}}", "refId": "A"}]
    },
    {
