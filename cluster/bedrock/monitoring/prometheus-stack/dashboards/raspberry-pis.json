      "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "editorMode": "code", "expr": "(1 - node_filesystem_avail_bytes{job=\"kiosk-nodes\", mountpoint=\"/\", instance=~\"$instance\"} / node_filesystem_size_bytes{job=\"kiosk-nodes\", mountpoint=\"/\", instance=~\"$instance\"}) * 100", "legendFormat": "{{instance}}", "refId": "A"}]
