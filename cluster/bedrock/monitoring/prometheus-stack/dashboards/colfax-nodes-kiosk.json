  "timezone": "",
  "title": "Colfax Nodes - Kiosk",
  "uid": "colfax-nodes-kiosk",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "bargauge",
      "title": "CPU Usage",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 24, "w": 8, "x": 0, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 0,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 70},
            {"color": "red", "value": 90}
          ]}
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true,
        "valueMode": "color",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "editorMode": "code",
        "expr": "(100 - (avg by(instance)(rate(node_cpu_seconds_total{job=\"node-exporter\", mode=\"idle\"}[5m])) * 100)) * on(instance) group_left(nodename) node_uname_info{job=\"node-exporter\"}",
        "legendFormat": "{{nodename}}",
        "instant": true,
        "range": false,
        "refId": "A"
      }]
    },
    {
      "id": 2,
      "type": "bargauge",
      "title": "Memory Usage",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 24, "w": 8, "x": 8, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 0,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 80},
            {"color": "red", "value": 90}
          ]}
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true,
        "valueMode": "color",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "editorMode": "code",
        "expr": "((1 - node_memory_MemAvailable_bytes{job=\"node-exporter\"} / node_memory_MemTotal_bytes{job=\"node-exporter\"}) * 100) * on(instance) group_left(nodename) node_uname_info{job=\"node-exporter\"}",
        "legendFormat": "{{nodename}}",
        "instant": true,
        "range": false,
        "refId": "A"
      }]
    },
    {
      "id": 3,
      "type": "bargauge",
      "title": "Load Average (1m)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 24, "w": 8, "x": 16, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "decimals": 2,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 8},
            {"color": "red", "value": 16}
          ]}
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true,
        "valueMode": "color",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "editorMode": "code",
        "expr": "node_load1{job=\"node-exporter\"} * on(instance) group_left(nodename) node_uname_info{job=\"node-exporter\"}",
        "legendFormat": "{{nodename}}",
        "instant": true,
        "range": false,
        "refId": "A"
      }]
    }
  ]
}
